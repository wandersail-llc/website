---
import type { Project } from '@/data/projects';

interface Props {
  project: Project;
}

const { project } = Astro.props;
const isSoon = project.status === 'coming_soon';
---

<div class:list={['p-6 hover:bg-surface transition-colors', isSoon && 'opacity-70']}>
  <span class="block text-[0.65rem] uppercase tracking-widest text-[var(--color-text-muted)] mb-2">{project.category}</span>
  <h3 class="font-serif text-lg text-[var(--color-text-primary)] mb-2">{project.name}</h3>
  <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed mb-3">{project.description}</p>
  <div class="flex items-center justify-between">
    <span class="flex items-center gap-1.5 text-xs text-[var(--color-text-muted)]">
      <span class:list={[
        'inline-block w-1.5 h-1.5 rounded-full',
        isSoon ? 'bg-[var(--color-status-soon)]' : 'bg-[var(--color-status-active)]',
      ]}></span>
      {isSoon ? 'Coming Soon' : 'Active'}
    </span>
    {project.url && !isSoon ? (
      <a href={project.url} target="_blank" rel="noopener" class="text-sm text-[var(--color-text-secondary)] no-underline hover:border-b hover:border-[var(--color-text-secondary)]">
        Visit →
      </a>
    ) : null}
  </div>
</div>
