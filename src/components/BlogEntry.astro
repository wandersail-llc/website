---
interface Props {
  title: string;
  date: Date;
  category?: string;
  href: string;
}

const { title, date, category, href } = Astro.props;
---

<div class="flex justify-between items-baseline py-4 border-b border-rule last:border-b-0">
  <div>
    <a href={href} class="font-serif text-base text-[var(--color-text-primary)] no-underline hover:border-b hover:border-[var(--color-text-primary)]">{title}</a>
    {category && (
      <span class="text-[0.65rem] uppercase tracking-widest text-[var(--color-text-muted)] ml-3">{category}</span>
    )}
  </div>
  <time class="text-sm text-[var(--color-text-muted)] ml-4 shrink-0">
    {date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
  </time>
</div>
