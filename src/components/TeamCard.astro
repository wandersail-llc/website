---
import type { TeamMember } from '@/data/team';

interface Props {
  member: TeamMember;
}

const { member } = Astro.props;
---

<div class="py-8 border-b border-rule last:border-b-0">
  <div class="flex items-start gap-5">
    <div class="w-16 h-16 rounded-full shrink-0 bg-surface flex items-center justify-center text-lg font-serif text-[var(--color-text-secondary)] overflow-hidden">
      {member.photo ? (
        <img src={member.photo} alt={member.name} class="w-full h-full object-cover" />
      ) : (
        member.initials || member.name.charAt(0)
      )}
    </div>
    <div>
      <div class="font-serif text-base text-[var(--color-text-primary)]">{member.name}</div>
      <div class="text-sm text-[var(--color-text-muted)] mb-2">{member.role}</div>
      {member.bio && <p class="text-sm text-[var(--color-text-secondary)] mb-3">{member.bio}</p>}
      <div class="flex gap-3">
        {member.links.github && (
          <a href={member.links.github} target="_blank" rel="noopener" class="text-sm text-[var(--color-text-muted)] no-underline hover:text-[var(--color-text-primary)] hover:border-b hover:border-[var(--color-text-muted)]">GitHub</a>
        )}
        {member.links.linkedin && (
          <a href={member.links.linkedin} target="_blank" rel="noopener" class="text-sm text-[var(--color-text-muted)] no-underline hover:text-[var(--color-text-primary)] hover:border-b hover:border-[var(--color-text-muted)]">LinkedIn</a>
        )}
        {member.links.twitter && (
          <a href={member.links.twitter} target="_blank" rel="noopener" class="text-sm text-[var(--color-text-muted)] no-underline hover:text-[var(--color-text-primary)] hover:border-b hover:border-[var(--color-text-muted)]">Twitter</a>
        )}
      </div>
    </div>
  </div>
</div>
