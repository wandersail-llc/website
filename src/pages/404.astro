---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="404" description="Page not found.">
  <div class="max-w-content mx-auto px-4 sm:px-6">
    <div class="pt-10 sm:pt-16 pb-6 sm:pb-8">
      <h1 class="font-serif text-[clamp(1.5rem,3vw,2.25rem)] text-[var(--color-text-primary)]">404</h1>
    </div>
    <section class="max-w-prose pb-12 sm:pb-20 text-[clamp(0.95rem,1.5vw,1.05rem)] leading-relaxed text-[var(--color-text-secondary)]">
      <blockquote class="border-l-[2px] border-rule pl-5 my-8 font-serif text-xl text-[var(--color-text-primary)] italic leading-snug">
        You've drifted off course.
      </blockquote>
      <p>
        The page you're looking for isn't here. <a href="/" class="text-[var(--color-text-primary)] no-underline border-b border-rule hover:border-[var(--color-text-primary)]">Head back to shore</a>.
      </p>
    </section>
  </div>
</BaseLayout>
