---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ContactForm from '@/components/ContactForm.astro';
---

<BaseLayout title="Contact" description="Get in touch with Wandersail.">
  <div class="max-w-content mx-auto px-4 sm:px-6">
    <div class="pt-10 sm:pt-16 pb-6 sm:pb-8">
      <h1 class="font-serif text-[clamp(1.5rem,3vw,2.25rem)] text-[var(--color-text-primary)]">Contact</h1>
      <p class="text-[clamp(0.9rem,1.5vw,1.05rem)] text-[var(--color-text-secondary)] mt-2">Have a question or want to work together? Reach out.</p>
    </div>
    <section class="pb-12 sm:pb-20">
      <ContactForm formspreeId="YOUR_FORMSPREE_ID" />
    </section>
  </div>
</BaseLayout>
